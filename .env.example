# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=8916165919:AAFGEFOyjQ83ynFfPGyzKOqvvFcRZxGgAXg

# ── Google OAuth (לצורך כניסה לאתר) ──────────────────────
# 1. https://console.cloud.google.com → New Project
# 2. APIs & Services → Credentials → Create → OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorized redirect URIs: http://localhost:8000/auth/callback
# 5. Copy Client ID and Client Secret here
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Web Server ────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_BASE_URL=http://localhost:8000
SECRET_KEY=change-this-to-a-random-secret-key-32chars

# ── Monitoring ────────────────────────────────────────────
CHECK_INTERVAL_SECONDS=120

# ── Email (SMTP) — אופציונלי, ישלח מיילים למי שחיבר חשבון Google ──
# Gmail: הפעל 2FA ← Google Account → Security → App Passwords → צור App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password-16-chars
SMTP_FROM=Ticket Monitor <your@gmail.com>
